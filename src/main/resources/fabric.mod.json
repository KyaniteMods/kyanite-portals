{
  "schemaVersion": 1,
  "id": "kyaniteportals",
  "version": "0.1.4",
  "name": "Kyanite Portals",
  "description": "An API for creating portals",
  "authors": [
    "Kyanite Mods (Pedro Ricardo)"
  ],
  "contact": {
    "website": "https://kyanitemods.dev"
  },
  "license": "MIT",
  "icon": "assets/kyanite_portals/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "dev.kyanitemods.kyaniteportals.client.KyanitePortalsClient"
    ],
    "main": [
      "dev.kyanitemods.kyaniteportals.KyanitePortals"
    ]
  },
  "mixins": [
    "kyaniteportals.mixins.json",
    {
      "config": "kyaniteportals.client.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "kyaniteportals.classtweaker",
  "depends": {
    "fabricloader": ">=0.18.2",
    "fabric": "*",
    "minecraft": "${minecraft}"
  }
}
